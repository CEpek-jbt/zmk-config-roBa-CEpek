#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

#undef ZMK_POINTING_DEFAULT_SCRL_VAL

#define ZMK_POINTING_DEFAULT_SCRL_VAL 100
#define MOUSE 4
#define SCROLL 5
#define NUM 6
#define NASAL 7
#define PLOSIVE 8
#define NSFRICATIVE 9
#define NSAFFRICATE 10
#define SFRICATIVE 11
#define SAFFRICATE 12
#define LFRICATIVE 13
#define LAFFRICATE 14
#define APPROXIMANT 15
#define LAPPROXIMANT 16
#define TAP 17
#define LTAP 18
#define TRILL 19
#define IMPLO 20
#define LAT_IMPLO 21  // 追加: Lateral implosive layer

// 視認性とメンテナンス向上のためのエイリアス
#define TR &trans

&mt {
    flavor = "hold-preferred";
    quick-tap-ms = <0>;
};

&sl { release-after-ms = <250>; };

&trackball {
    automouse-layer = <4>;
    scroll-layers = <5>;
};

/ {
macros {
        ipa_sw: ipa_sw {
            compatible = "zmk,behavior-macro-two-param";
            #binding-cells = <2>;
            wait-ms = <0>;
            tap-ms = <1>;
            bindings =
                <&macro_param_1to1>,
                <&macro_press>,
                <&mo MACRO_PLACEHOLDER>,
                <&macro_pause_for_release>,
                <&macro_param_1to1>,
                <&macro_release>,
                <&mo MACRO_PLACEHOLDER>;
        };

        to_layer_0: to_layer_0 {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            bindings = <&to 0 &macro_param_1to1 &kp MACRO_PLACEHOLDER>;
        };

        mkp_exit_AML: mkp_exit_AML {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            bindings =
                <&macro_press>,
                <&macro_param_1to1 &mkp MACRO_PLACEHOLDER>,
                <&macro_pause_for_release>,
                <&macro_release>,
                <&macro_param_1to1 &mkp MACRO_PLACEHOLDER>,
                <&macro_tap>,
                <&sl 4>;
        };

        parenthesis: parenthesis {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LANG_HANJA &kp LEFT_PARENTHESIS &kp RIGHT_PARENTHESIS &kp LEFT_ARROW>;
        };

        // ==========================================
        // レイヤー用のIPAマクロジェネレータ
        // ==========================================
        #define MAC_IPA(NAME, HEX1, HEX2, HEX3, HEX4) \
            NAME: NAME { \
                compatible = "zmk,behavior-macro"; \
                #binding-cells = <0>; \
                wait-ms = <10>; tap-ms = <10>; \
                bindings = <&macro_press &kp LALT>, <&macro_tap &kp HEX1 &kp HEX2 &kp HEX3 &kp HEX4>, <&macro_release &kp LALT>; \
            };

        // ==========================================
        // 追加: IPA ダイアクリティック用出力マクロ
        // ==========================================
        MAC_IPA(mac_ipa_030D, N0, N3, N0, D)
        MAC_IPA(mac_ipa_0329, N0, N3, N2, N9)
        MAC_IPA(mac_ipa_0311, N0, N3, N1, N1)
        MAC_IPA(mac_ipa_032F, N0, N3, N2, F)
        MAC_IPA(mac_ipa_02B0, N0, N2, B, N0)
        MAC_IPA(mac_ipa_02B1, N0, N2, B, N1)
        MAC_IPA(mac_ipa_1D4D, N1, D, N4, D)
        MAC_IPA(mac_ipa_207F, N2, N0, N7, F)
        MAC_IPA(mac_ipa_1DAF, N1, D, A, F)
        MAC_IPA(mac_ipa_1DAE, N1, D, A, E)
        MAC_IPA(mac_ipa_1D51, N1, D, N5, N1)
        MAC_IPA(mac_ipa_02E1, N0, N2, E, N1)
        MAC_IPA(mac_ipa_1D4A, N1, D, N4, A)
        MAC_IPA(mac_ipa_1DBF, N1, D, B, F)
        MAC_IPA(mac_ipa_02E3, N0, N2, E, N3)
        MAC_IPA(mac_ipa_031A, N0, N3, N1, A)
        MAC_IPA(mac_ipa_030A, N0, N3, N0, A)
        MAC_IPA(mac_ipa_0325, N0, N3, N2, N5)
        MAC_IPA(mac_ipa_032C, N0, N3, N2, C)
        MAC_IPA(mac_ipa_0308, N0, N3, N0, N8)
        MAC_IPA(mac_ipa_0324, N0, N3, N2, N4)
        MAC_IPA(mac_ipa_0303, N0, N3, N0, N3)
        MAC_IPA(mac_ipa_0330, N0, N3, N3, N0)
        MAC_IPA(mac_ipa_032A, N0, N3, N2, A)
        MAC_IPA(mac_ipa_033A, N0, N3, N3, A)
        MAC_IPA(mac_ipa_031F, N0, N3, N1, F)
        MAC_IPA(mac_ipa_0320, N0, N3, N2, N0)
        MAC_IPA(mac_ipa_031D, N0, N3, N1, D)
        MAC_IPA(mac_ipa_031E, N0, N3, N1, E)
        MAC_IPA(mac_ipa_033B, N0, N3, N3, B)
        MAC_IPA(mac_ipa_033C, N0, N3, N3, C)
        MAC_IPA(mac_ipa_033D, N0, N3, N3, D)
        MAC_IPA(mac_ipa_0357, N0, N3, N5, N7)
        MAC_IPA(mac_ipa_0339, N0, N3, N3, N9)
        MAC_IPA(mac_ipa_0351, N0, N3, N5, N1)
        MAC_IPA(mac_ipa_031C, N0, N3, N1, C)
        MAC_IPA(mac_ipa_02B7, N0, N2, B, N7)
        MAC_IPA(mac_ipa_02E0, N0, N2, E, N0)
        MAC_IPA(mac_ipa_02E4, N0, N2, E, N4)
        MAC_IPA(mac_ipa_02C0, N0, N2, C, N0)
        MAC_IPA(mac_ipa_0318, N0, N3, N1, N8)
        MAC_IPA(mac_ipa_0319, N0, N3, N1, N9)
        MAC_IPA(mac_ipa_02B2, N0, N2, B, N2)
        MAC_IPA(mac_ipa_026B, N0, N2, N6, B)
        MAC_IPA(mac_ipa_02DE, N0, N2, D, E)
        MAC_IPA(mac_ipa_0361, N0, N3, N6, N1)
        MAC_IPA(mac_ipa_035C, N0, N3, N5, C)
        MAC_IPA(mac_ipa_02C8, N0, N2, C, N8)
        MAC_IPA(mac_ipa_02CC, N0, N2, C, C)
        MAC_IPA(mac_ipa_02D0, N0, N2, D, N0)
        MAC_IPA(mac_ipa_02D1, N0, N2, D, N1)
        MAC_IPA(mac_ipa_0306, N0, N3, N0, N6)
        MAC_IPA(mac_ipa_032E, N0, N3, N2, E)
        MAC_IPA(mac_ipa_203F, N2, N0, N3, F)
        MAC_IPA(mac_ipa_007C, N0, N0, N7, C)
        MAC_IPA(mac_ipa_2016, N2, N0, N1, N6)
        MAC_IPA(mac_ipa_2197, N2, N1, N9, N7)
        MAC_IPA(mac_ipa_2198, N2, N1, N9, N8)
        MAC_IPA(mac_ipa_A71B, A, N7, N1, B)
        MAC_IPA(mac_ipa_A71C, A, N7, N1, C)
        MAC_IPA(mac_ipa_0301, N0, N3, N0, N1)
        MAC_IPA(mac_ipa_030B, N0, N3, N0, B)
        MAC_IPA(mac_ipa_0300, N0, N3, N0, N0)
        MAC_IPA(mac_ipa_030F, N0, N3, N0, F)
        MAC_IPA(mac_ipa_02E9, N0, N2, E, N9)
        MAC_IPA(mac_ipa_02E8, N0, N2, E, N8)
        MAC_IPA(mac_ipa_02E7, N0, N2, E, N7)
        MAC_IPA(mac_ipa_02E6, N0, N2, E, N6)
        MAC_IPA(mac_ipa_02E5, N0, N2, E, N5)
        MAC_IPA(mac_ipa_0304, N0, N3, N0, N4)
        MAC_IPA(mac_ipa_0331, N0, N3, N3, N1)
        MAC_IPA(mac_ipa_0302, N0, N3, N0, N2)
        MAC_IPA(mac_ipa_032D, N0, N3, N2, D)
        MAC_IPA(mac_ipa_030C, N0, N3, N0, C)
        MAC_IPA(mac_ipa_0327, N0, N3, N2, N7)
        MAC_IPA(mac_ipa_02BB, N0, N2, B, B)
        MAC_IPA(mac_ipa_0326, N0, N3, N2, N6)
        MAC_IPA(mac_ipa_0307, N0, N3, N0, N7)
        MAC_IPA(mac_ipa_0323, N0, N3, N2, N3)
        MAC_IPA(mac_ipa_0309, N0, N3, N0, N9)
        MAC_IPA(mac_ipa_031B, N0, N3, N1, B)
        MAC_IPA(mac_ipa_0328, N0, N3, N2, N8)
        MAC_IPA(mac_ipa_0335, N0, N3, N3, N5)
        MAC_IPA(mac_ipa_309B, N3, N0, N9, B)
        MAC_IPA(mac_ipa_309C, N3, N0, N9, C)
        MAC_IPA(mac_ipa_0265, N0, N2, N6, N5)
        MAC_IPA(mac_ipa_028D, N0, N2, N8, D)
        MAC_IPA(mac_ipa_0267, N0, N2, N6, N7)

        // 合字・複数文字からなるIPA記号用のマクロ
        mac_ipa_006E_0361_006D: mac_ipa_006E_0361_006D {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>; wait-ms = <10>; tap-ms = <10>;
            bindings = <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N0 &kp N6 &kp E>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N3 &kp N6 &kp N1>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N0 &kp N6 &kp D>, <&macro_release &kp LALT>;
        };
        mac_ipa_0273_0361_006D: mac_ipa_0273_0361_006D {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>; wait-ms = <10>; tap-ms = <10>;
            bindings = <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N2 &kp N7 &kp N3>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N3 &kp N6 &kp N1>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N0 &kp N6 &kp D>, <&macro_release &kp LALT>;
        };
        mac_ipa_014B_0361_006D: mac_ipa_014B_0361_006D {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>; wait-ms = <10>; tap-ms = <10>;
            bindings = <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N1 &kp N4 &kp B>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N3 &kp N6 &kp N1>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N0 &kp N6 &kp D>, <&macro_release &kp LALT>;
        };
        mac_ipa_0074_0361_0070: mac_ipa_0074_0361_0070 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>; wait-ms = <10>; tap-ms = <10>;
            bindings = <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N0 &kp N7 &kp N4>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N3 &kp N6 &kp N1>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N0 &kp N7 &kp N0>, <&macro_release &kp LALT>;
        };
        mac_ipa_0064_0361_0062: mac_ipa_0064_0361_0062 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>; wait-ms = <10>; tap-ms = <10>;
            bindings = <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N0 &kp N6 &kp N4>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N3 &kp N6 &kp N1>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N0 &kp N6 &kp N2>, <&macro_release &kp LALT>;
        };
        mac_ipa_0288_0361_0070: mac_ipa_0288_0361_0070 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>; wait-ms = <10>; tap-ms = <10>;
            bindings = <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N2 &kp N8 &kp N8>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N3 &kp N6 &kp N1>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N0 &kp N7 &kp N0>, <&macro_release &kp LALT>;
        };
        mac_ipa_0256_0361_0062: mac_ipa_0256_0361_0062 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>; wait-ms = <10>; tap-ms = <10>;
            bindings = <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N2 &kp N5 &kp N6>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N3 &kp N6 &kp N1>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N0 &kp N6 &kp N2>, <&macro_release &kp LALT>;
        };
        mac_ipa_006B_0361_0070: mac_ipa_006B_0361_0070 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>; wait-ms = <10>; tap-ms = <10>;
            bindings = <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N0 &kp N6 &kp B>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N3 &kp N6 &kp N1>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N0 &kp N7 &kp N0>, <&macro_release &kp LALT>;
        };
        mac_ipa_0067_0361_0062: mac_ipa_0067_0361_0062 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>; wait-ms = <10>; tap-ms = <10>;
            bindings = <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N0 &kp N6 &kp N7>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N3 &kp N6 &kp N1>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N0 &kp N6 &kp N2>, <&macro_release &kp LALT>;
        };
        mac_ipa_0071_0361_02A1: mac_ipa_0071_0361_02A1 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>; wait-ms = <10>; tap-ms = <10>;
            bindings = <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N0 &kp N7 &kp N1>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N3 &kp N6 &kp N1>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N2 &kp A &kp N1>, <&macro_release &kp LALT>;
        };
        mac_ipa_0071_0361_0070: mac_ipa_0071_0361_0070 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>; wait-ms = <10>; tap-ms = <10>;
            bindings = <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N0 &kp N7 &kp N1>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N3 &kp N6 &kp N1>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N0 &kp N7 &kp N0>, <&macro_release &kp LALT>;
        };
        mac_ipa_0265_030A: mac_ipa_0265_030A {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>; wait-ms = <10>; tap-ms = <10>;
            bindings = <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N2 &kp N6 &kp N5>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N3 &kp N0 &kp A>, <&macro_release &kp LALT>;
        };
        mac_ipa_0260_030A_035C_0253_0325: mac_ipa_0260_030A_035C_0253_0325 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>; wait-ms = <10>; tap-ms = <10>;
            bindings = <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N2 &kp N6 &kp N0>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N3 &kp N0 &kp A>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N3 &kp N5 &kp C>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N2 &kp N5 &kp N3>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N3 &kp N2 &kp N5>, <&macro_release &kp LALT>;
        };
        mac_ipa_0260_0361_0253: mac_ipa_0260_0361_0253 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>; wait-ms = <10>; tap-ms = <10>;
            bindings = <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N2 &kp N6 &kp N0>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N3 &kp N6 &kp N1>, <&macro_release &kp LALT>,
                       <&macro_press &kp LALT>, <&macro_tap &kp N0 &kp N2 &kp N5 &kp N3>, <&macro_release &kp LALT>;
        };

        // ==========================================
        // Vowels (母音群)
        // ==========================================
        // Layer 8 (close)
        MAC_IPA(m_v_8_1, N0, N0, N0, N0)  // ʉ (W 1)
        MAC_IPA(m_v_8_2, N0, N0, N0, N0)  // ɯ (E 2)
        MAC_IPA(m_v_8_5, N0, N0, N0, N0)  // y (Y 5)
        MAC_IPA(m_v_8_6, N0, N0, N0, N0)  // u (U 6)
        MAC_IPA(m_v_8_7, N0, N0, N0, N0)  // i (I 7)
        MAC_IPA(m_v_8_10, N0, N0, N0, N0) // ɨ (A 10)

        // Layer 11 (Near-close)
        MAC_IPA(m_v_11_1, N0, N0, N0, N0)  // ʉ̞ (W 1)
        MAC_IPA(m_v_11_2, N0, N0, N0, N0)  // ɯ̞ (E 2)
        MAC_IPA(m_v_11_5, N0, N0, N0, N0)  // ʏ (Y 5)
        MAC_IPA(m_v_11_6, N0, N0, N0, N0)  // ʊ (U 6)
        MAC_IPA(m_v_11_7, N0, N0, N0, N0)  // ɪ (I 7)
        MAC_IPA(m_v_11_10, N0, N0, N0, N0) // ɨ̞ (A 10)

        // Layer 9 (close-mid)
        MAC_IPA(m_v_9_1, N0, N0, N0, N0)  // ɵ (W 1)
        MAC_IPA(m_v_9_2, N0, N0, N0, N0)  // ɤ (E 2)
        MAC_IPA(m_v_9_5, N0, N0, N0, N0)  // ø (Y 5)
        MAC_IPA(m_v_9_6, N0, N0, N0, N0)  // o (U 6)
        MAC_IPA(m_v_9_7, N0, N0, N0, N0)  // e (I 7)
        MAC_IPA(m_v_9_10, N0, N0, N0, N0) // ɘ (A 10)

        // Layer 15 (mid)
        MAC_IPA(m_v_15_1, N0, N0, N0, N0)  // ɵ̞ (W 1)
        MAC_IPA(m_v_15_2, N0, N0, N0, N0)  // ɤ̞ (E 2)
        MAC_IPA(m_v_15_5, N0, N0, N0, N0)  // ø̞ (Y 5)
        MAC_IPA(m_v_15_6, N0, N0, N0, N0)  // o̞ (U 6)
        MAC_IPA(m_v_15_7, N0, N0, N0, N0)  // e̞ (I 7)
        MAC_IPA(m_v_15_10, N0, N0, N0, N0) // ə (A 10)

        // Layer 17 (open-mid)
        MAC_IPA(m_v_17_1, N0, N0, N0, N0)  // ɞ (W 1)
        MAC_IPA(m_v_17_2, N0, N0, N0, N0)  // ʌ (E 2)
        MAC_IPA(m_v_17_5, N0, N0, N0, N0)  // œ (Y 5)
        MAC_IPA(m_v_17_6, N0, N0, N0, N0)  // ɔ (U 6)
        MAC_IPA(m_v_17_7, N0, N0, N0, N0)  // ɛ (I 7)
        MAC_IPA(m_v_17_10, N0, N0, N0, N0) // з (A 10)

        // Layer 19 (Near-open)
        MAC_IPA(m_v_19_1, N0, N0, N0, N0)  // ɞ̞ (W 1)
        MAC_IPA(m_v_19_2, N0, N0, N0, N0)  // ɑ̝ (E 2)
        MAC_IPA(m_v_19_5, N0, N0, N0, N0)  // œ̞ (Y 5)
        MAC_IPA(m_v_19_6, N0, N0, N0, N0)  // ɒ̝ (U 6)
        MAC_IPA(m_v_19_7, N0, N0, N0, N0)  // æ (I 7)
        MAC_IPA(m_v_19_10, N0, N0, N0, N0) // ɐ (A 10)

        // Layer 20 (Open)
        MAC_IPA(m_v_20_1, N0, N0, N0, N0)  // ɒ̈ (W 1)
        MAC_IPA(m_v_20_2, N0, N0, N0, N0)  // ɑ (E 2)
        MAC_IPA(m_v_20_5, N0, N0, N0, N0)  // ɶ (Y 5)
        MAC_IPA(m_v_20_6, N0, N0, N0, N0)  // ɒ (U 6)
        MAC_IPA(m_v_20_7, N0, N0, N0, N0)  // a (I 7)
        MAC_IPA(m_v_20_10, N0, N0, N0, N0) // ä (A 10)


        // 新規追加: Bilabial (両唇音) & Labiodental (唇歯音)
        MAC_IPA(m_n_bil_vl, N0, N0, N0, N0) MAC_IPA(m_n_bil_vd, N0, N0, N0, N0)
        MAC_IPA(m_n_lab_vl, N0, N0, N0, N0) MAC_IPA(m_n_lab_vd, N0, N0, N0, N0)

        MAC_IPA(m_p_bil_vl, N0, N0, N0, N0) MAC_IPA(m_p_bil_vd, N0, N0, N0, N0)
        MAC_IPA(m_p_lab_vl, N0, N0, N0, N0) MAC_IPA(m_p_lab_vd, N0, N0, N0, N0)

        MAC_IPA(m_nsf_bil_vl, N0, N0, N0, N0) MAC_IPA(m_nsf_bil_vd, N0, N0, N0, N0)
        MAC_IPA(m_nsf_lab_vl, N0, N0, N0, N0) MAC_IPA(m_nsf_lab_vd, N0, N0, N0, N0)

        MAC_IPA(m_nsa_bil_vl, N0, N0, N0, N0) MAC_IPA(m_nsa_bil_vd, N0, N0, N0, N0)
        MAC_IPA(m_nsa_lab_vl, N0, N0, N0, N0) MAC_IPA(m_nsa_lab_vd, N0, N0, N0, N0)

        MAC_IPA(m_ap_bil_vd, N0, N0, N0, N0)
        MAC_IPA(m_ap_lab_vd, N0, N0, N0, N0)

        MAC_IPA(m_tap_bil_vd, N0, N0, N0, N0)
        MAC_IPA(m_tap_lab_vd, N0, N0, N0, N0)

        MAC_IPA(m_tr_bil_vl, N0, N0, N0, N0) MAC_IPA(m_tr_bil_vd, N0, N0, N0, N0)

        MAC_IPA(m_im_bil_vl, N0, N0, N0, N0) MAC_IPA(m_im_bil_vd, N0, N0, N0, N0)


        // Layer 7: Nasal
        MAC_IPA(m_n_den_vl, N0, N3, N2, A) MAC_IPA(m_n_den_vd, N0, N0, N6, E)
        MAC_IPA(m_n_alv_vl, N0, N3, N2, B) MAC_IPA(m_n_alv_vd, N0, N0, N6, E)
        MAC_IPA(m_n_palv_vl, N0, N3, N2, C) MAC_IPA(m_n_palv_vd, N0, N3, N2, D)
        MAC_IPA(m_n_ret_vl, N0, N2, N7, N3) MAC_IPA(m_n_ret_vd, N0, N2, N7, N3)
        MAC_IPA(m_n_pal_vl, N0, N2, N7, N2) MAC_IPA(m_n_pal_vd, N0, N2, N7, N2)
        MAC_IPA(m_n_vel_vl, N0, N1, N4, B) MAC_IPA(m_n_vel_vd, N0, N1, N4, B)
        MAC_IPA(m_n_uvu_vl, N0, N2, N7, N4) MAC_IPA(m_n_uvu_vd, N0, N2, N7, N4)

        // Layer 8: Plosive
        MAC_IPA(m_p_den_vl, N0, N0, N7, N4) MAC_IPA(m_p_den_vd, N0, N0, N6, N4)
        MAC_IPA(m_p_alv_vl, N0, N0, N7, N4) MAC_IPA(m_p_alv_vd, N0, N0, N6, N4)
        MAC_IPA(m_p_ret_vl, N0, N2, N8, N8) MAC_IPA(m_p_ret_vd, N0, N2, N5, N6)
        MAC_IPA(m_p_pal_vl, N0, N0, N6, N3) MAC_IPA(m_p_pal_vd, N0, N2, N5, F)
        MAC_IPA(m_p_vel_vl, N0, N0, N6, B) MAC_IPA(m_p_vel_vd, N0, N0, N6, N7)
        MAC_IPA(m_p_uvu_vl, N0, N0, N7, N1) MAC_IPA(m_p_uvu_vd, N0, N2, N6, N2)
        MAC_IPA(m_p_epi_vl, N0, N2, A, N1) MAC_IPA(m_p_epi_vd, N0, N2, N9, N4)

        // Layer 9: Non-sibilant fricative
        MAC_IPA(m_nsf_den_vl, N0, N3, B, N8) MAC_IPA(m_nsf_den_vd, N0, N0, F, N0)
        MAC_IPA(m_nsf_alv_vl, N0, N3, B, N8) MAC_IPA(m_nsf_alv_vd, N0, N0, F, N0)
        MAC_IPA(m_nsf_palv_vl, N0, N2, N7, N9) MAC_IPA(m_nsf_palv_vd, N0, N2, N7, N9)
        MAC_IPA(m_nsf_ret_vl, N0, N2, N7, B) MAC_IPA(m_nsf_ret_vd, N0, N2, N7, B)
        MAC_IPA(m_nsf_pal_vl, N0, N0, E, N7) MAC_IPA(m_nsf_pal_vd, N0, N2, N9, D)
        MAC_IPA(m_nsf_vel_vl, N0, N0, N7, N8) MAC_IPA(m_nsf_vel_vd, N0, N0, N2, N6)
        MAC_IPA(m_nsf_uvu_vl, N0, N3, C, N7) MAC_IPA(m_nsf_uvu_vd, N0, N2, N8, N1)
        MAC_IPA(m_nsf_epi_vl, N0, N1, N2, N7) MAC_IPA(m_nsf_epi_vd, N0, N2, N9, N5)
        MAC_IPA(m_nsf_glo_vl, N0, N0, N6, N8) MAC_IPA(m_nsf_glo_vd, N0, N2, N6, N6)

        // Layer 10: Non-sibilant Affricate
        MAC_IPA(m_nsa_den_vl, N0, N0, N0, N0) MAC_IPA(m_nsa_den_vd, N0, N0, N0, N0)
        MAC_IPA(m_nsa_alv_vl, N0, N0, N0, N0) MAC_IPA(m_nsa_alv_vd, N0, N0, N0, N0)
        MAC_IPA(m_nsa_palv_vl, N0, N0, N0, N0) MAC_IPA(m_nsa_palv_vd, N0, N0, N0, N0)
        MAC_IPA(m_nsa_ret_vl, N0, N0, N0, N0) MAC_IPA(m_nsa_ret_vd, N0, N0, N0, N0)
        MAC_IPA(m_nsa_pal_vl, N0, N0, N0, N0) MAC_IPA(m_nsa_pal_vd, N0, N0, N0, N0)
        MAC_IPA(m_nsa_vel_vl, N0, N0, N0, N0) MAC_IPA(m_nsa_vel_vd, N0, N0, N0, N0)
        MAC_IPA(m_nsa_uvu_vl, N0, N0, N0, N0) MAC_IPA(m_nsa_uvu_vd, N0, N0, N0, N0)
        MAC_IPA(m_nsa_epi_vl, N0, N0, N0, N0) MAC_IPA(m_nsa_epi_vd, N0, N0, N0, N0)
        MAC_IPA(m_nsa_glo_vl, N0, N0, N0, N0) 

        // Layer 11: Sibilant fricative
        MAC_IPA(m_sf_den_vl, N0, N0, N7, N3) MAC_IPA(m_sf_den_vd, N0, N0, N7, A)
        MAC_IPA(m_sf_alv_vl, N0, N0, N7, N3) MAC_IPA(m_sf_alv_vd, N0, N0, N7, A)
        MAC_IPA(m_sf_palv_vl, N0, N2, N8, N3) MAC_IPA(m_sf_palv_vd, N0, N2, N9, N2)
        MAC_IPA(m_sf_ret_vl, N0, N2, N8, N2) MAC_IPA(m_sf_ret_vd, N0, N2, N9, N0)
        MAC_IPA(m_sf_pal_vl, N0, N2, N5, N5) MAC_IPA(m_sf_pal_vd, N0, N2, N9, N1)

        // Layer 12: Sibilant Affricate
        MAC_IPA(m_sa_den_vl, N0, N0, N0, N0) MAC_IPA(m_sa_den_vd, N0, N0, N0, N0)
        MAC_IPA(m_sa_alv_vl, N0, N0, N0, N0) MAC_IPA(m_sa_alv_vd, N0, N0, N0, N0)
        MAC_IPA(m_sa_palv_vl, N0, N0, N0, N0) MAC_IPA(m_sa_palv_vd, N0, N0, N0, N0)
        MAC_IPA(m_sa_ret_vl, N0, N0, N0, N0) MAC_IPA(m_sa_ret_vd, N0, N0, N0, N0)
        MAC_IPA(m_sa_pal_vl, N0, N0, N0, N0) MAC_IPA(m_sa_pal_vd, N0, N0, N0, N0)
        MAC_IPA(m_sa_vel_vl, N0, N0, N0, N0) MAC_IPA(m_sa_vel_vd, N0, N0, N0, N0)
        MAC_IPA(m_sa_uvu_vl, N0, N0, N0, N0) MAC_IPA(m_sa_uvu_vd, N0, N0, N0, N0)
        MAC_IPA(m_sa_epi_vl, N0, N0, N0, N0) MAC_IPA(m_sa_epi_vd, N0, N0, N0, N0)
        MAC_IPA(m_sa_glo_vl, N0, N0, N0, N0)

        // Layer 13: Lateral Fricative
        MAC_IPA(m_lf_den_vl, N0, N2, N6, C) MAC_IPA(m_lf_den_vd, N0, N2, N6, E)
        MAC_IPA(m_lf_alv_vl, N0, N2, N6, C) MAC_IPA(m_lf_alv_vd, N0, N2, N6, E)
        MAC_IPA(m_lf_ret_vl, N0, N2, N6, D) MAC_IPA(m_lf_ret_vd, N0, N2, N6, D)
        MAC_IPA(m_lf_pal_vl, N0, N2, N8, E) MAC_IPA(m_lf_pal_vd, N0, N2, N8, E)
        MAC_IPA(m_lf_vel_vl, N0, N2, N9, F) MAC_IPA(m_lf_vel_vd, N0, N2, N9, F)

        // Layer 14: Lateral Affricate
        MAC_IPA(m_la_alv_vl, N0, N0, N0, N0) MAC_IPA(m_la_alv_vd, N0, N0, N0, N0)
        MAC_IPA(m_la_ret_vl, N0, N0, N0, N0) MAC_IPA(m_la_ret_vd, N0, N0, N0, N0)
        MAC_IPA(m_la_pal_vl, N0, N0, N0, N0) MAC_IPA(m_la_pal_vd, N0, N0, N0, N0)
        MAC_IPA(m_la_vel_vl, N0, N0, N0, N0) MAC_IPA(m_la_vel_vd, N0, N0, N0, N0)

        // Layer 15: Approximant
        MAC_IPA(m_ap_den_vd, N0, N0, F, N0)
        MAC_IPA(m_ap_alv_vd, N0, N2, N7, N9)
        MAC_IPA(m_ap_palv_vd, N0, N2, N7, N9)
        MAC_IPA(m_ap_ret_vd, N0, N2, N7, B)
        MAC_IPA(m_ap_pal_vd, N0, N0, N6, A)
        MAC_IPA(m_ap_vel_vd, N0, N2, N7, N0)

        // Layer 16: Lateral Approximant
        MAC_IPA(m_lap_den_vl, N0, N0, N6, C) MAC_IPA(m_lap_den_vd, N0, N0, N6, C)
        MAC_IPA(m_lap_alv_vd, N0, N0, N6, C)
        MAC_IPA(m_lap_ret_vl, N0, N2, N6, D) MAC_IPA(m_lap_ret_vd, N0, N2, N6, D)
        MAC_IPA(m_lap_pal_vl, N0, N2, N8, E) MAC_IPA(m_lap_pal_vd, N0, N2, N8, E)
        MAC_IPA(m_lap_vel_vl, N0, N2, N9, F) MAC_IPA(m_lap_vel_vd, N0, N2, N9, F)
        MAC_IPA(m_lap_uvu_vd, N0, N0, N0, N0)

        // Layer 17: Tap/Flap
        MAC_IPA(m_tap_alv_vl, N0, N2, N7, E) MAC_IPA(m_tap_alv_vd, N0, N2, N7, E)
        MAC_IPA(m_tap_ret_vl, N0, N2, N7, D) MAC_IPA(m_tap_ret_vd, N0, N2, N7, D)
        MAC_IPA(m_tap_uvu_vd, N0, N0, N0, N0)
        MAC_IPA(m_tap_epi_vd, N0, N0, N0, N0)

        // Layer 18: Lateral Tap/Flap
        MAC_IPA(m_ltap_alv_vl, N0, N2, N7, A) MAC_IPA(m_ltap_alv_vd, N0, N2, N7, A)
        MAC_IPA(m_ltap_ret_vl, N0, N0, N0, N0) MAC_IPA(m_ltap_ret_vd, N0, N0, N0, N0)
        MAC_IPA(m_ltap_pal_vd, N0, N0, N0, N0)
        MAC_IPA(m_ltap_vel_vd, N0, N0, N0, N0)

        // Layer 19: Trill
        MAC_IPA(m_tr_alv_vl, N0, N0, N7, N2) MAC_IPA(m_tr_alv_vd, N0, N0, N7, N2)
        MAC_IPA(m_tr_palv_vd, N0, N0, N0, N0) MAC_IPA(m_tr_ret_vl, N0, N0, N0, N0) MAC_IPA(m_tr_ret_vd, N0, N0, N0, N0)
        MAC_IPA(m_tr_uvu_vl, N0, N2, N8, N0) MAC_IPA(m_tr_uvu_vd, N0, N2, N8, N0)
        MAC_IPA(m_tr_epi_vl, N0, N2, N9, C) MAC_IPA(m_tr_epi_vd, N0, N2, A, N2)

        // Layer 20: Implosive
        MAC_IPA(m_im_den_vl, N0, N1, C, N0)
        MAC_IPA(m_im_alv_vl, N0, N1, C, N3) MAC_IPA(m_im_alv_vd, N0, N2, N5, N7)
        MAC_IPA(m_im_palv_vl, N2, N0, N3, C) MAC_IPA(m_im_palv_vd, N1, D, N9, N1)
        MAC_IPA(m_im_ret_vl, N0, N1, C, N2) MAC_IPA(m_im_ret_vd, N0, N2, N8, N4)
        MAC_IPA(m_im_pal_vl, N0, N1, C, N1) MAC_IPA(m_im_pal_vd, N0, N2, N6, N0)
        MAC_IPA(m_im_uvu_vd, N0, N2, N9, B)

        // Layer 21: Lateral Implosive
        MAC_IPA(m_lim_den_vl, N0, N1, C, N1)
    };


    combos {
        compatible = "zmk,combos";

        BT0 {
            bindings = <&bt BT_SEL 0>;
            key-positions = <28>;
        };

        BT1 {
            bindings = <&bt BT_SEL 1>;
            key-positions = <28 23>;
        };

        BT2 {
            bindings = <&bt BT_SEL 2>;
            key-positions = <28 24>;
        };

        combo_nsaffricate {
            timeout-ms = <50>;
            key-positions = <34 36>;
            bindings = <&ipa_sw 10 0>;
        };

        combo_saffricate {
            timeout-ms = <50>;
            key-positions = <34 35>;
            bindings = <&ipa_sw 12 0>;
        };

        combo_lfricative {
            timeout-ms = <50>;
            key-positions = <35 41>;
            bindings = <&ipa_sw 13 0>;
        };

        combo_laffricate {
            timeout-ms = <50>;
            key-positions = <34 35 41>;
            bindings = <&ipa_sw 14 0>;
        };

        combo_lapproximant {
            timeout-ms = <50>;
            key-positions = <37 41>;
            bindings = <&ipa_sw 16 0>;
        };

        combo_ltap {
            timeout-ms = <50>;
            key-positions = <38 41>;
            bindings = <&ipa_sw 18 0>;
        };

