        combo_PSS { timeout-ms = <300>; key-positions = <9 11 11>; bindings = <&mac_ipa_A71B>; };
        combo_DWS { timeout-ms = <300>; key-positions = <12 1 11>; bindings = <&mac_ipa_A71C>; };
        combo_AC_2 { timeout-ms = <300>; key-positions = <10 24>; bindings = <&mac_ipa_0301>; };
        combo_DAC { timeout-ms = <300>; key-positions = <12 10 24>; bindings = <&mac_ipa_030B>; };
        combo_GR { timeout-ms = <300>; key-positions = <14 3>; bindings = <&mac_ipa_0300>; };
        combo_DGR { timeout-ms = <300>; key-positions = <12 14 3>; bindings = <&mac_ipa_030F>; };
        combo_LT { timeout-ms = <300>; key-positions = <20 4>; bindings = <&mac_ipa_02E9>; };
        combo_HLT { timeout-ms = <300>; key-positions = <17 20 4>; bindings = <&mac_ipa_02E8>; };
        combo_MT { timeout-ms = <300>; key-positions = <30 4>; bindings = <&mac_ipa_02E7>; };
        combo_HHT { timeout-ms = <300>; key-positions = <17 17 4>; bindings = <&mac_ipa_02E6>; };
        combo_HT { timeout-ms = <300>; key-positions = <17 4>; bindings = <&mac_ipa_02E5>; };
        combo_MC { timeout-ms = <300>; key-positions = <30 24>; bindings = <&mac_ipa_0304>; };
        combo_MCB { timeout-ms = <300>; key-positions = <30 24 26>; bindings = <&mac_ipa_0331>; };
        combo_CR { timeout-ms = <300>; key-positions = <24 3>; bindings = <&mac_ipa_0302>; };
        combo_CRB { timeout-ms = <300>; key-positions = <24 3 26>; bindings = <&mac_ipa_032D>; };
        combo_HC { timeout-ms = <300>; key-positions = <17 24>; bindings = <&mac_ipa_030C>; };
        combo_HCB { timeout-ms = <300>; key-positions = <17 24 26>; bindings = <&mac_ipa_032C>; };
        combo_CD { timeout-ms = <300>; key-positions = <24 12>; bindings = <&mac_ipa_0327>; };
        combo_CM { timeout-ms = <300>; key-positions = <24 30>; bindings = <&mac_ipa_02BB>; };
        combo_CMB { timeout-ms = <300>; key-positions = <24 30 26>; bindings = <&mac_ipa_0326>; };
        combo_IB_2 { timeout-ms = <300>; key-positions = <7 26>; bindings = <&mac_ipa_0311>; };
        combo_IBB { timeout-ms = <300>; key-positions = <7 26 26>; bindings = <&mac_ipa_032F>; };
        combo_DT_2 { timeout-ms = <300>; key-positions = <12 4>; bindings = <&mac_ipa_0307>; };
        combo_DTB { timeout-ms = <300>; key-positions = <12 4 26>; bindings = <&mac_ipa_0323>; };
        combo_HK { timeout-ms = <300>; key-positions = <17 19>; bindings = <&mac_ipa_0309>; };
        combo_HR { timeout-ms = <300>; key-positions = <17 3>; bindings = <&mac_ipa_031B>; };
        combo_OG { timeout-ms = <300>; key-positions = <8 14>; bindings = <&mac_ipa_0328>; };
        combo_RG { timeout-ms = <300>; key-positions = <3 14>; bindings = <&mac_ipa_030A>; };
        combo_ST { timeout-ms = <300>; key-positions = <11 4>; bindings = <&mac_ipa_0335>; };
        combo_DK { timeout-ms = <300>; key-positions = <12 19>; bindings = <&mac_ipa_309B>; };
        combo_HD { timeout-ms = <300>; key-positions = <17 12>; bindings = <&mac_ipa_309C>; };
        combo_EJ { timeout-ms = <300>; key-positions = <2 18>; bindings = <&mac_ipa_02BC>; };
        combo_NM { timeout-ms = <300>; key-positions = <29 30>; bindings = <&mac_ipa_006E_0361_006D>; };
        combo_RNM { timeout-ms = <300>; key-positions = <3 29 30>; bindings = <&mac_ipa_0273_0361_006D>; };
        combo_NGM { timeout-ms = <300>; key-positions = <29 14 30>; bindings = <&mac_ipa_014B_0361_006D>; };
        combo_TP { timeout-ms = <300>; key-positions = <4 9>; bindings = <&mac_ipa_0074_0361_0070>; };
        combo_DB { timeout-ms = <300>; key-positions = <12 26>; bindings = <&mac_ipa_0064_0361_0062>; };
        combo_RTP { timeout-ms = <300>; key-positions = <3 4 9>; bindings = <&mac_ipa_0288_0361_0070>; };
        combo_RDB_2 { timeout-ms = <300>; key-positions = <3 12 26>; bindings = <&mac_ipa_0256_0361_0062>; };
        combo_KP { timeout-ms = <300>; key-positions = <19 9>; bindings = <&mac_ipa_006B_0361_0070>; };
        combo_GB { timeout-ms = <300>; key-positions = <14 26>; bindings = <&mac_ipa_0067_0361_0062>; };
        combo_QH { timeout-ms = <300>; key-positions = <0 17>; bindings = <&mac_ipa_0071_0361_02A1>; };
        combo_QP { timeout-ms = <300>; key-positions = <0 9>; bindings = <&mac_ipa_0071_0361_0070>; };
        combo_HYY { timeout-ms = <300>; key-positions = <17 5 5>; bindings = <&mac_ipa_0265_030A>; };
        combo_YY { timeout-ms = <300>; key-positions = <5 5>; bindings = <&mac_ipa_0265>; };
        combo_HW { timeout-ms = <300>; key-positions = <17 1>; bindings = <&mac_ipa_028D>; };
        combo_SJ { timeout-ms = <300>; key-positions = <11 18>; bindings = <&mac_ipa_0267>; };
        combo_MKP { timeout-ms = <300>; key-positions = <30 19 9>; bindings = <&mac_ipa_0260_030A_035C_0253_0325>; };
        combo_MGB { timeout-ms = <300>; key-positions = <30 14 26>; bindings = <&mac_ipa_0260_0361_0253>; };
    };

    behaviors {
        scroll_up_down: behavior_sensor_rotate_mouse_wheel_up_down {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&msc SCRL_DOWN &msc SCRL_UP>;
            tap-ms = <20>;
        };

        lt_ipa: lt_ipa {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <150>;
            flavor = "hold-preferred";
            bindings = <&ipa_sw>, <&kp>;
        };

        lt_NUM: lt_NUM {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            bindings = <&mo>, <&kp>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
&kp Q             &kp W             &kp E             &kp R             &kp T                                        &kp Y                  &kp U         &kp I      &kp O    &kp P
&kp A             &kp S             &kp D             &kp F             &kp G             &mkp MB1             &lt_NUM 6 EQUAL  &kp H                  &kp J         &kp K      &kp L    &lt 5 ASTRK
&kp Z             &kp X             &kp C             &kp V             &kp B             &mt LEFT_SHIFT TAB   &lt_ipa 20 BSLH  &lt_ipa 7 N            &lt_ipa 20 M  &kp COMMA  &kp DOT  &kp SEMICOLON
&lt_ipa 8 K_COPY  &lt_ipa 11 K_PASTE  &lt_ipa 9 K_UNDO  &lt_ipa 15 LANG2  &lt_ipa 17 SPACE  &lt_ipa 19 LANG1     &kp BACKSPACE    &mt RIGHT_SHIFT ENTER                                  &kp DEL
            >;
            sensor-bindings = <&scroll_up_down>;
        };

        SYMBOLS {
            bindings = <
&kp ESCAPE  &kp AMPERSAND    &kp ASTERISK  &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS                      &kp LEFT_PARENTHESIS  &kp RIGHT_PARENTHESIS  &trans         &trans             &trans
&kp TILDE   &kp DOLLAR       &kp PERCENT   &kp CARET             &trans                 &trans      &trans  &kp LEFT_BRACE        &kp RIGHT_BRACE        &kp SEMICOLON  &kp SINGLE_QUOTE   &kp BACKSLASH
&kp GRAVE   &kp EXCLAMATION  &kp AT_SIGN   &kp HASH              &trans                 &trans      &trans  &kp LEFT_BRACKET      &kp RIGHT_BRACKET      &kp COLON      &kp DOUBLE_QUOTES  &kp PIPE
&trans      &trans           &trans        &trans                &trans                 &trans      &trans  &trans                                                                         &trans
            >;
        };

        NUM {
            bindings = <
&kp MINUS                   &kp KP_NUMBER_7  &kp KP_NUMBER_8  &kp KP_NUMBER_9  &kp PLUS                               &trans  &kp F7  &kp F8  &kp F9  &kp F10
&kp SLASH                   &kp KP_NUMBER_4  &kp KP_NUMBER_5  &kp KP_NUMBER_6  &kp ASTERISK  &kp LC(LA(KP_NUMBER_0))  &trans  &trans      &kp F4  &kp F5  &kp F6  &kp F11
&mt LEFT_SHIFT KP_NUMBER_0  &kp KP_NUMBER_1  &kp KP_NUMBER_2  &kp KP_NUMBER_3  &kp PERIOD    &kp EQUAL                &trans  &kp ESCAPE  &kp F1  &kp F2  &kp F3  &kp F12
&trans                      &trans           &trans           &trans           &trans        &trans                   &trans  &trans                              &kp F13
            >;
        };

        ARROW {
            bindings = <
&kp LG(LEFT_ARROW)  &kp LC(LS(TAB))         &kp UP_ARROW    &kp LC(TAB)          &kp LG(RIGHT_ARROW)                      &kp LG(LEFT_ARROW)  &kp LS(LC(TAB))         &kp UP_ARROW    &kp LC(TAB)          &kp LG(RIGHT_ARROW)
&kp HOME            &kp LEFT_ARROW          &kp DOWN_ARROW  &kp RIGHT_ARROW      &kp END              &trans      &trans  &kp HOME            &kp LEFT_ARROW          &kp DOWN_ARROW  &kp RIGHT_ARROW      &kp END
&kp LEFT_SHIFT      &kp LG(LC(LEFT_ARROW))  &trans          &kp LG(LC(RIGHT_ARROW)) &trans            &trans      &trans  &trans              &kp LC(LG(LEFT_ARROW))  &trans          &kp LC(LG(RIGHT_ARROW)) &trans
&trans              &trans                  &trans          &trans               &trans               &trans      &trans  &trans                                                                           &trans
            >;
            sensor-bindings = <&inc_dec_kp LC(PAGE_UP) LC(PAGE_DOWN)>;
        };

        MOUSE {
            bindings = <
&to_layer_0 0  &to_layer_0 0  &to_layer_0 0  &to_layer_0 0  &to_layer_0 0                                 &to_layer_0 0    &to_layer_0 0      &kp LC(T)          &to_layer_0 0      &m_n_bil_vl
&to_layer_0 0  &to_layer_0 0  &to_layer_0 0  &to_layer_0 0  &to_layer_0 0  &trans             &kp LC(V)  &kp LC(LS(TAB))  &mkp_exit_AML MB1  &mkp_exit_AML MB3  &mkp_exit_AML MB2  &kp LC(TAB)
&to_layer_0 0  &to_layer_0 0  &to_layer_0 0  &to_layer_0 0  &m_n_bil_vd    &trans             &kp LC(C)  &to_layer_0 0    &mkp MB4           &kp LC(W)          &mkp MB5           &trans
&trans         &trans         &trans         &to_layer_0 0  &trans         &to_layer_0 0      &trans     &trans                                                                    &trans
            >;
        };

        SCROLL {
            bindings = <
&trans  &trans  &trans  &trans  &trans                                &trans  &trans             &trans  &trans  &m_im_bil_vl
&trans  &trans  &trans  &trans  &trans        &trans      &trans  &trans  &mkp_exit_AML MB1  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &lt_ipa 20 0  &trans      &trans  &trans  &trans             &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans        &trans      &trans  &trans                                     &trans
            >;
        };

        layer_6 {
            bindings = <
&trans  &trans        &trans        &trans        &trans                                      &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3  &bt BT_SEL 4
&trans  &trans        &trans        &trans        &trans        &trans        &trans  &trans      &trans        &trans        &trans        &trans        &trans        &trans
&trans  &kp NUMBER_1  &kp NUMBER_2  &kp NUMBER_3  &trans        &trans      &bootloader  &trans        &trans        &trans        &trans        &trans        &bt BT_CLR
&trans  &trans        &trans        &trans        &trans        &trans  &trans      &trans        &trans                                                  &bt BT_CLR_ALL
            >;
        };

        // ==========================================
        // IPA Layers (表に従った配置)
        // 表のキー対応: q(0),r(3),t(4),y(5),p(9),s(11),d(12),f(13),g(14),h(17),j(18),k(19),'/(21),z(22),x(23),c(24),v(25),b(26),n(29),m(30),,(31),.(32)
        // ==========================================

        NASAL { // Layer 7
            bindings = <
&m_n_uvu_vl  TR  TR  &m_n_uvu_vd  &m_n_den_vl                    &m_n_pal_vd  TR            TR  TR            &m_n_bil_vl
TR  &m_n_alv_vl  &m_n_den_vd  &m_n_lab_vl  &m_n_vel_vd  TR        TR  TR  &m_n_palv_vd &m_n_vel_vl  TR  TR
&m_n_alv_vd  &m_n_palv_vl  &m_n_pal_vl  &m_n_lab_vd  &m_n_bil_vd  TR      TR  &m_n_uvu_vl  &m_n_uvu_vd  &m_n_ret_vl  &m_n_ret_vd  TR
TR  TR  TR  TR  TR  TR                                  TR  TR            TR
            >;
        };

        PLOSIVE { // Layer 8 (close)
            bindings = <
&m_p_uvu_vl  &m_v_8_1  &m_v_8_2  &m_p_uvu_vd  &m_p_den_vl                    &m_v_8_5     &m_v_8_6      &m_v_8_7      TR            &m_p_bil_vl
&m_v_8_10    &m_p_alv_vl  &m_p_den_vd  &m_p_lab_vl  &m_p_vel_vd  TR        TR  TR  &m_p_pal_vd  &m_p_vel_vl  TR  &m_p_epi_vd
&m_p_alv_vd  TR            &m_p_pal_vl  &m_p_lab_vd  &m_p_bil_vd  TR      TR  &m_p_epi_vl  &m_p_epi_vd  &m_p_ret_vl  &m_p_ret_vd  TR
TR  TR  TR  TR  TR  TR                                  TR  TR            TR
            >;
        };

        NSFRICATIVE { // Layer 9 (close-mid)
            bindings = <
&m_nsf_uvu_vl &m_v_9_1  &m_v_9_2  &m_nsf_uvu_vd &m_nsf_den_vl                &m_v_9_5     &m_v_9_6      &m_v_9_7      TR            &m_nsf_bil_vl
&m_v_9_10     &m_nsf_alv_vl &m_nsf_den_vd &m_nsf_lab_vl  &m_nsf_vel_vd TR    TR  TR  &m_nsf_palv_vd &m_nsf_vel_vl TR  &m_nsf_glo_vd
&m_nsf_alv_vd &m_nsf_palv_vl &m_nsf_pal_vl &m_nsf_lab_vd &m_nsf_bil_vd TR      TR  &m_nsf_epi_vl &m_nsf_epi_vd &m_nsf_ret_vl &m_nsf_ret_vd TR
TR  TR  TR  TR  TR  TR                                  TR  TR            TR
            >;
        };

        NSAFFRICATE { // Layer 10
            bindings = <
&m_nsa_uvu_vl TR  TR  &m_nsa_uvu_vd &m_nsa_den_vl                &m_nsa_pal_vd TR            TR  TR            &m_nsa_bil_vl
TR  &m_nsa_alv_vl &m_nsa_den_vd &m_nsa_lab_vl  &m_nsa_vel_vd TR    TR  TR  &m_nsa_palv_vd &m_nsa_vel_vl TR  &m_nsa_glo_vl
&m_nsa_alv_vd &m_nsa_palv_vl &m_nsa_pal_vl &m_nsa_lab_vd &m_nsa_bil_vd TR      TR  &m_nsa_epi_vl &m_nsa_epi_vd &m_nsa_ret_vl &m_nsa_ret_vd TR
TR  TR  TR  TR  TR  TR                                  TR  TR            TR
            >;
        };

        SFRICATIVE { // Layer 11 (Near-close)
            bindings = <
TR            &m_v_11_1  &m_v_11_2  TR  &m_sf_den_vl                         &m_v_11_5    &m_v_11_6     &m_v_11_7     TR            TR
&m_v_11_10    &m_sf_alv_vl  &m_sf_den_vd  TR  TR  TR              TR  TR  &m_sf_palv_vd TR            TR  TR
&m_sf_alv_vd  &m_sf_palv_vl  &m_sf_pal_vl  TR  TR  TR  TR  TR  TR              &m_sf_ret_vl &m_sf_ret_vd TR
TR  TR  TR  TR  TR  TR                                  TR  TR            TR
            >;
        };

        SAFFRICATE { // Layer 12
            bindings = <
&m_sa_uvu_vl TR  TR  &m_sa_uvu_vd &m_sa_den_vl                &m_sa_pal_vd TR            TR  TR            TR
TR  &m_sa_alv_vl  &m_sa_den_vd  TR  &m_sa_vel_vd TR      TR  TR  &m_sa_palv_vd &m_sa_vel_vl TR &m_sa_glo_vl
&m_sa_alv_vd  &m_sa_palv_vl  &m_sa_pal_vl  TR  TR  TR  TR  &m_sa_epi_vl &m_sa_epi_vd &m_sa_ret_vl &m_sa_ret_vd TR
TR  TR  TR  TR  TR  TR                                  TR  TR            TR
            >;
        };

        LFRICATIVE { // Layer 13
            bindings = <
TR  TR  TR  TR  &m_lf_den_vl                                &m_lf_pal_vd TR            TR  TR            TR
TR  &m_lf_alv_vl  &m_lf_den_vd  TR  &m_lf_vel_vd TR      TR  TR  TR              &m_lf_vel_vl TR  TR
&m_lf_alv_vd  TR            &m_lf_pal_vl  TR  TR  TR    TR  TR  TR              &m_lf_ret_vl &m_lf_ret_vd TR
TR  TR  TR  TR  TR  TR                                  TR  TR            TR
            >;
        };

        LAFFRICATE { // Layer 14
            bindings = <
TR  TR  TR  TR  TR                                              &m_la_pal_vd TR            TR  TR            TR
TR  &m_la_alv_vl  TR  TR  &m_la_vel_vd TR                TR  TR  TR              &m_la_vel_vl TR  TR
&m_la_alv_vd  TR            &m_la_pal_vl  TR  TR  TR    TR  TR  TR              &m_la_ret_vl &m_la_ret_vd TR
TR  TR  TR  TR  TR  TR                                  TR  TR            TR
            >;
        };

        APPROXIMANT { // Layer 15 (mid)
            bindings = <
TR            &m_v_15_1  &m_v_15_2  TR  TR                                   &m_v_15_5    &m_v_15_6     &m_v_15_7     TR            TR
&m_v_15_10    TR  &m_ap_den_vd  TR  &m_ap_vel_vd TR                TR  TR  &m_ap_palv_vd TR            TR  TR
&m_ap_alv_vd  TR            TR  &m_ap_lab_vd  &m_ap_bil_vd  TR              TR  TR  TR              TR            &m_ap_ret_vd TR
TR  TR  TR  TR  TR  TR                                  TR  TR            TR
            >;
        };

        LAPPROXIMANT { // Layer 16
            bindings = <
TR  TR  TR  TR  &m_lap_den_vl                                   &m_lap_pal_vd TR            TR  TR            TR
TR  &m_lap_alv_vd &m_lap_den_vd TR  &m_lap_vel_vd TR    TR  TR  TR               &m_lap_vel_vl TR  TR
TR  TR            &m_lap_pal_vl TR  TR  TR              TR  TR  &m_lap_uvu_vd &m_lap_ret_vl &m_lap_ret_vd TR
TR  TR  TR  TR  TR  TR                                  TR  TR            TR
            >;
        };

        TAP { // Layer 17 (open-mid)
            bindings = <
TR            &m_v_17_1  &m_v_17_2  &m_tap_uvu_vd TR                         &m_v_17_5    &m_v_17_6     &m_v_17_7     TR            TR
&m_v_17_10    &m_tap_alv_vl TR  TR  TR  TR                                TR  TR  TR              TR            TR  TR
&m_tap_alv_vd TR            TR  &m_tap_lab_vd  &m_tap_bil_vd  TR                  TR  &m_tap_epi_vd TR          &m_tap_ret_vl &m_tap_ret_vd TR
TR  TR  TR  TR  TR  TR                                  TR  TR            TR
            >;
        };

        LTAP { // Layer 18
            bindings = <
TR  TR  TR  TR  TR                                              &m_ltap_pal_vd TR          TR  TR            TR
TR  &m_ltap_alv_vl TR  TR  &m_ltap_vel_vd TR            TR  TR  TR              TR            TR  TR
&m_ltap_alv_vd TR            TR  TR  TR  TR                TR  TR              TR            &m_ltap_ret_vl &m_ltap_ret_vd TR
TR  TR  TR  TR  TR  TR                                  TR  TR            TR
            >;
        };

        TRILL { // Layer 19 (Near-open)
            bindings = <
&m_tr_uvu_vl  &m_v_19_1  &m_v_19_2  &m_tr_uvu_vd &m_tr_alv_vl                &m_v_19_5    &m_v_19_6     &m_v_19_7     TR            &m_tr_bil_vl
&m_v_19_10    &m_tr_alv_vd TR  TR  TR  TR                                TR  TR  &m_tr_palv_vd TR            TR  TR
TR  TR            TR  TR  &m_tr_bil_vd  TR                              TR  &m_tr_epi_vl &m_tr_epi_vd &m_tr_ret_vl &m_tr_ret_vd TR
TR  TR  TR  TR  TR  TR                                  TR  TR            TR
            >;
        };

        IMPLO { // Layer 20 (Open)
            bindings = <
&m_im_uvu_vd  &m_v_20_1  &m_v_20_2  TR  &m_im_den_vl                         &m_v_20_5    &m_v_20_6     &m_v_20_7     TR            &m_im_bil_vl
&m_v_20_10    &m_im_alv_vl &m_im_alv_vd TR  &m_im_pal_vl TR        TR  TR  &m_im_palv_vd TR            TR  TR
TR  &m_im_palv_vl TR  TR  &m_im_bil_vd  TR                              TR  TR            TR            &m_im_ret_vl &m_im_ret_vd TR
TR  TR  TR  TR  TR  TR                                  TR  TR            TR
            >;
        };

        LAT_IMPLO { // Layer 21 (新規追加)
            bindings = <
TR  TR  TR  TR  &m_lim_den_vl                                   TR            TR            TR  TR            TR
TR  TR  TR  TR  TR  TR                                      TR  TR  TR              TR            TR  TR
TR  TR  TR  TR  TR  TR                                      TR  TR              TR            TR  TR            TR
TR  TR  TR  TR  TR  TR                                  TR  TR            TR
            >;
        };
    };
};
