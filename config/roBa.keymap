keymap {
        compatible = "zmk,keymap";

        default_layer {
            bindings = <
&kp Q             &kp W         &kp E         &kp R      &kp T                                          &kp Y        &kp U  &kp I      &kp O    &kp P
&kp A             &kp S         &kp D         &kp F      &kp G        &kp LCTRL          &kp MINUS      &kp H        &kp J  &kp K      &kp L    &kp SEMI
&mt LSHIFT Z      &kp X         &kp C         &kp V      &kp B        &kp LALT           &kp EQUAL      &kp N        &kp M  &kp COMMA  &kp DOT  &kp SLASH
&lt MOUSE ESCAPE  &lt NUM LALT  &kp LEFT_WIN  &lt NUM 0  &lt NUM TAB  &lt NUM ENTER      &lt NUM SPACE  &lt NUM TAB                             &lt NUM BACKSPACE
            >;
        };

        MOUSE {
            bindings = <
&trans  &trans  &trans  &trans  &trans                      &trans  &trans    &trans    &trans    &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &mkp LCLK  &mkp MCLK  &mkp RCLK  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &trans    &trans    &trans    &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans                                &trans
            >;
        };

        SCROLL {
            bindings = <
&trans  &trans  &trans  &trans  &trans                      &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans  &trans  &trans  &trans  &trans
&trans  &trans  &trans  &trans  &trans  &trans      &trans  &trans                          &trans
            >;
        };

        NUM {
            bindings = <
&kp ESCAPE      &kp N7        &kp N8        &kp N9        &kp N0                                  &sl NASAL        &sl PLOSIVE      &sl NSFRICATIVE  &sl NSAFFRICATE  &kp BSPC
&kp TAB         &kp N4        &kp N5        &kp N6        &kp ENTER  &trans               &trans  &sl SFRICATIVE   &sl SAFFRICATE   &sl LFRICATIVE   &sl LAFFRICATE   &kp ENTER
&kp LSHFT       &kp N1        &kp N2        &kp N3        &kp DEL    &kp LALT             &trans  &sl APPROXIMANT  &sl LAPPROXIMANT &sl TAP          &sl LTAP         &sl TRILL
&sl LAT_IMPLO   &sl IMPLO     &trans        &trans        &trans     &trans               &trans  &trans                                                              &kp BSPC
            >;
        };

        NASAL {
            bindings = <
&trans  &trans   &trans   &trans    &trans                    &n_uv_vd  &trans  &trans  &trans  &n_bi_vd
&trans  &n_re_vd &n_al_vd &n_de_vd  &n_la_vd  &trans  &trans  &trans    &trans  &trans  &trans  &trans
&trans  &trans   &trans   &trans    &n_pa_vd  &trans  &trans  &trans    &trans  &trans  &n_ve_vd  &trans
&trans  &trans   &trans   &trans    &trans    &trans  &trans  &trans                            &trans
            >;
        };

        PLOSIVE {
            bindings = <
