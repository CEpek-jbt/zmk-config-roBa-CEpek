behaviors {
    scroll_up_down: behavior_sensor_rotate_mouse_wheel_up_down {
        compatible = "zmk,behavior-sensor-rotate";
        #sensor-binding-cells = <0>;
        bindings = <&msc SCRL_DOWN &msc SCRL_UP>;
        tap-ms = <20>;
    };

    ipa_sw: lt_ipa {
        compatible = "zmk,behavior-hold-tap";
        #binding-cells = <2>;
        tapping-term-ms = <150>;
        flavor = "hold-preferred";
        bindings = <&mo 1 &kp A>;
    };

    lt_NUM: lt_NUM {
        compatible = "zmk,behavior-hold-tap";
        #binding-cells = <2>;
        tapping-term-ms = <200>;
        bindings = <&mo NUM &kp A>;
    };
};

/{
macros {
    // Solution 4: Enhanced macro-based Unicode input for macOS
    // Using proper macro press/release sequences with Option key
    
    mac_ipa_030D: mac_ipa_030D {
        compatible = "zmk,behavior-macro";
        #binding-cells = <0>;
        wait-ms = <0>;
        tap-ms = <0>;
        bindings = <&macro_press &kp LALT>, <&macro_tap &kp U &kp N0 &kp N3 &kp N0 &kp D>, <&macro_release &kp LALT>;
    };

    mac_ipa_0329: mac_ipa_0329 {
        compatible = "zmk,behavior-macro";
        #binding-cells = <0>;
        wait-ms = <0>;
        tap-ms = <0>;
        bindings = <&macro_press &kp LALT>, <&macro_tap &kp U &kp N0 &kp N3 &kp N2 &kp N9>, <&macro_release &kp LALT>;
    };

    mac_ipa_0311: mac_ipa_0311 {
        compatible = "zmk,behavior-macro";
        #binding-cells = <0>;
        wait-ms = <0>;
        tap-ms = <0>;
        bindings = <&macro_press &kp LALT>, <&macro_tap &kp U &kp N0 &kp N3 &kp N1 &kp N1>, <&macro_release &kp LALT>;
    };

    mac_ipa_032F: mac_ipa_032F {
        compatible = "zmk,behavior-macro";
        #binding-cells = <0>;
        wait-ms = <0>;
        tap-ms = <0>;
        bindings = <&macro_press &kp LALT>, <&macro_tap &kp U &kp N0 &kp N3 &kp N2 &kp F>, <&macro_release &kp LALT>;
    };

    mac_ipa_02B0: mac_ipa_02B0 {
        compatible = "zmk,behavior-macro";
        #binding-cells = <0>;
        wait-ms = <0>;
        tap-ms = <0>;
        bindings = <&macro_press &kp LALT>, <&macro_tap &kp U &kp N0 &kp N2 &kp B &kp N0>, <&macro_release &kp LALT>;
    };

    mac_ipa_02B1: mac_ipa_02B1 {
        compatible = "zmk,behavior-macro";
        #binding-cells = <0>;
        wait-ms = <0>;
        tap-ms = <0>;
        bindings = <&macro_press &kp LALT>, <&macro_tap &kp U &kp N0 &kp N2 &kp B &kp N1>, <&macro_release &kp LALT>;
    };

    mac_ipa_1D4D: mac_ipa_1D4D {
        compatible = "zmk,behavior-macro";
        #binding-cells = <0>;
        wait-ms = <0>;
        tap-ms = <0>;
        bindings = <&macro_press &kp LALT>, <&macro_tap &kp U &kp N1 &kp N4 &kp D &kp N4 &kp D>, <&macro_release &kp LALT>;
    };

    mac_ipa_207F: mac_ipa_207F {
        compatible = "zmk,behavior-macro";
        #binding-cells = <0>;
        wait-ms = <0>;
        tap-ms = <0>;
        bindings = <&macro_press &kp LALT>, <&macro_tap &kp U &kp N2 &kp N0 &kp N7 &kp F>, <&macro_release &kp LALT>;
    };

    mac_ipa_1DAF: mac_ipa_1DAF {
        compatible = "zmk,behavior-macro";
        #binding-cells = <0>;
        wait-ms = <0>;
        tap-ms = <0>;
        bindings = <&macro_press &kp LALT>, <&macro_tap &kp U &kp N1 &kp N4 &kp D &kp A &kp F>, <&macro_release &kp LALT>;
    };

    mac_ipa_1DAE: mac_ipa_1DAE {
        compatible = "zmk,behavior-macro";
        #binding-cells = <0>;
        wait-ms = <0>;
        tap-ms = <0>;
        bindings = <&macro_press &kp LALT>, <&macro_tap &kp U &kp N1 &kp N4 &kp D &kp A &kp E>, <&macro_release &kp LALT>;
    };

    mac_ipa_1D51: mac_ipa_1D51 {
        compatible = "zmk,behavior-macro";
        #binding-cells = <0>;
