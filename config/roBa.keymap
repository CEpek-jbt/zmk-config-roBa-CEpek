            #binding-cells = <0>;
            unicode-code = <0x026D 0x0331>;
        }; //  + macron below (voiced retroflex lateral fricative)
        
        // Lateral affricates (m_la_*)
        m_la_alv_vl: m_la_alv_vl {
            compatible = "zmk,behavior-unicode";
