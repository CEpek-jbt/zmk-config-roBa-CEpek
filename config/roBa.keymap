    combos {
        compatible = "zmk,combos";

        combo_SLA {
            timeout-ms = <50>;
            key-positions = <1 2>;
            bindings = <&mac_ipa_030D>;
        };

        combo_SYL {
            timeout-ms = <50>;
            key-positions = <2 3>;
            bindings = <&mac_ipa_0329>;
