        compatible = "zmk,keymap";

        default_layer {
            bindings = <
&kp Q    &kp W    &kp E    &kp R    &kp T    &kp Y    &kp U    &kp I    &kp O    &kp P
&kp A    &kp S    &kp D    &kp F    &kp G    &kp H    &kp J    &kp K    &kp L    &kp SEMI
&mt LS(Z) &kp X    &kp C    &kp V    &kp B    &kp N    &kp M    &kp COMMA &kp DOT  &kp SLSH
&kp ESC  &kp TAB  &kp LGUI &kp LALT &kp LSFT &kp SPC  &kp BSPC &kp DEL  &kp RET  &kp RALT
            >;
        };

        // Add other layers as needed...
    };
